{
  "name": "autogantt",
  "version": "1.26.2",
  "private": true,
  "type": "module",
  "main": "electron-main.js",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "lint": "node ./node_modules/eslint/bin/eslint.js . --max-warnings 0",
    "format:check": "node ./node_modules/prettier/bin/prettier.cjs . --check",
    "format": "node ./node_modules/prettier/bin/prettier.cjs . --write",
    "typecheck": "node ./node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "check": "node ./scripts/check.mjs",
    "prepare": "husky",
    "electron:build": "node ./node_modules/vite/bin/vite.js build && node ./node_modules/electron-builder/cli.js --win --x64"
  },
  "build": {
    "appId": "com.autogantt.app",
    "productName": "AutoGantt",
    "forceCodeSigning": false,
    "files": [
      "dist/**/*",
      "electron-main.js"
    ],
    "win": {
      "target": "portable",
      "icon": "public/icon.ico"
    }
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "description": "AutoGantt web app",
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@esbuild/win32-x64": "^0.21.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.14",
    "husky": "^9.1.6",
    "lint-staged": "^15.4.3",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
